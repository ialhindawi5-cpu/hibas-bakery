# ----- Database (Neon Postgres) -----
# Connection string from Neon or Vercel Storage → Create Database → Neon.
DATABASE_URL=

# ----- Order/contact notifications: Resend (easiest) -----
# Create a free account at resend.com → API Keys → copy the key.
# If set, this is used instead of Gmail (no app password / 2FA needed).
# Notifications are received at the "Order notifications email" set in the admin.
RESEND_API_KEY=
# Optional: a verified sender. Leave blank to use Resend's shared test sender,
# which can only deliver to the email you signed up to Resend with.
RESEND_FROM=

# ----- Order notification email (Gmail SMTP) — alternative to Resend -----
# The Gmail account that SENDS the emails, plus a Google "App Password"
# (Google account → Security → 2-Step Verification → App passwords).
# The address that RECEIVES orders is set in the admin dashboard (Settings → Order email).
GMAIL_USER=your-sending-address@gmail.com
GMAIL_APP_PASSWORD=

# ----- Admin dashboard login -----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password

# ----- Session signing secret -----
# Any long random string (e.g. run: openssl rand -base64 32)
AUTH_SECRET=

# ----- Rate limiting (Upstash Redis) — OPTIONAL -----
# Durable, cross-instance rate limiting for login + order spam.
# Create a free Redis database at console.upstash.com and paste the REST creds.
# If left blank, an in-memory limiter is used automatically.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
